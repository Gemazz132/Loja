# Porta do servidor
PORT=3000

# Ambiente: development | production
NODE_ENV=development

# Segredo das sessões (ALTERA para um valor longo e aleatório em produção)
SESSION_SECRET=troca-isto-por-um-segredo-bem-longo-e-aleatorio

# Credenciais do administrador inicial (usadas pelo seed)
ADMIN_EMAIL=admin@aurum.pt
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador AURUM

# ---- Email (recuperação de palavra-passe) ----
# Opcional: se não preencheres, a app funciona em "modo dev" e mostra o link de
# recuperação na resposta/consola em vez de enviar email a sério.
# Exemplos: Gmail (App Password), SendGrid, Mailgun, Resend, Brevo...
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=AURUM <no-reply@aurum.pt>
